# Environment Variables for AI-Powered WooCommerce Product Automation System
# Copy this file to .env and fill in your actual values

# WooCommerce API Credentials (get from WooCommerce > Settings > Advanced > REST API)
WOOCOMMERCE_API_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# WordPress Application Password (for media uploads)
# Go to: WordPress Admin > Users > Edit your user > Application Passwords
# Create a new application password and paste the generated password here
WP_USER=admin
WP_APP_PASSWORD=

# Image attachment mode: "gallery" (featured + gallery, no variation images) or "variation" (attach to variations)
IMAGE_ATTACHMENT_MODE=gallery

# OpenAI API (for AI-powered SEO content generation)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Excel Input/Output Paths
EXCEL_INPUT_PATH=input/Product_Master.csv
OUTPUT_DIR=../output
IMAGE_LOCAL_FOLDER=input/images
IMAGE_CACHE_DIR=output/image_cache